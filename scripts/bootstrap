#!/usr/bin/env python3

from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(REPO_ROOT / "lib"))

from codex_spine import (  # noqa: E402
    HOME,
    LIVE_CONFIG_PATH,
    LIVE_QMD_CHAT_LAUNCH_AGENT_PATH,
    LOCAL_CONFIG_EXAMPLE,
    LOCAL_CONFIG_OVERLAY,
    LOCAL_ENV_EXAMPLE,
    LOCAL_ENV_FILE,
    backup_existing,
    ensure_example_copy,
    ensure_symlink,
    managed_links,
    render_config_text,
    render_launch_agent_text,
    sanitize_zshenv,
    shell_source_targets,
    upsert_source_block,
    write_text,
)
from component_manager import resolve_components  # noqa: E402


def run_script(script_name: str, *args: str) -> None:
    subprocess.run([str(REPO_ROOT / "scripts" / script_name), *args], check=True)


def jcode_enabled() -> bool:
    return LOCAL_CONFIG_OVERLAY.exists() and "[mcp_servers.jcodemunch]" in LOCAL_CONFIG_OVERLAY.read_text(encoding="utf-8")


def maybe_offer_jcode() -> None:
    if jcode_enabled() or not sys.stdin.isatty():
        return
    reply = input("Enable optional jcode integration now? [y/N] ").strip().lower()
    if reply not in {"y", "yes"}:
        return
    run_script("component-enable", "jcode")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--non-interactive", action="store_true")
    args = parser.parse_args()

    ensure_example_copy(LOCAL_CONFIG_EXAMPLE, LOCAL_CONFIG_OVERLAY)
    ensure_example_copy(LOCAL_ENV_EXAMPLE, LOCAL_ENV_FILE)

    for path in [
        HOME / ".codex",
        HOME / ".codex/skills",
        HOME / ".local/bin",
        HOME / "Library/LaunchAgents",
    ]:
        path.mkdir(parents=True, exist_ok=True)

    for link in managed_links():
        ensure_symlink(link.live_path, link.repo_path)

    sanitize_zshenv(HOME / ".zshenv")
    for dotfile, fragment in shell_source_targets().items():
        upsert_source_block(dotfile, fragment)

    run_script("update", "--defaults-only", *(["--non-interactive"] if args.non_interactive else []))

    rendered = render_config_text()
    if LIVE_CONFIG_PATH.exists():
        current = LIVE_CONFIG_PATH.read_text(encoding="utf-8")
        if current != rendered and "Generated by codex-spine" not in current:
            backup_existing(LIVE_CONFIG_PATH)
    write_text(LIVE_CONFIG_PATH, rendered, mode=0o600)

    write_text(LIVE_QMD_CHAT_LAUNCH_AGENT_PATH, render_launch_agent_text(), mode=0o644)
    uid = subprocess.run(["id", "-u"], check=True, capture_output=True, text=True).stdout.strip()
    subprocess.run(["launchctl", "bootout", f"gui/{uid}", str(LIVE_QMD_CHAT_LAUNCH_AGENT_PATH)], check=False)
    subprocess.run(["launchctl", "bootstrap", f"gui/{uid}", str(LIVE_QMD_CHAT_LAUNCH_AGENT_PATH)], check=False)
    subprocess.run(["launchctl", "kickstart", "-k", f"gui/{uid}/io.codex.spine.qmd-codex-chat"], check=False)

    if not args.non_interactive:
        maybe_offer_jcode()

    run_script("verify")
    print("bootstrap: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
