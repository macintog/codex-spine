#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PYTHON_LAUNCHER="$REPO_ROOT/bin/codex-python"
BOOTSTRAP_PY="$SCRIPT_DIR/bootstrap.py"
BOOTSTRAP_PYTHON=""
LIVE_CONFIG_PATH="$HOME/.codex/config.toml"
ADOPTED_CONFIG_PATH="$REPO_ROOT/codex/config/80-adopted.toml"
LOCAL_CONFIG_OVERLAY_PATH="$REPO_ROOT/codex/config/90-local.toml"
COMPONENT_STATE_PATH="$REPO_ROOT/.state/components.toml"

find_brew() {
    if command -v brew >/dev/null 2>&1; then
        command -v brew
        return 0
    fi
    for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

brew_install_plan_prompt() {
    if [ -z "${1:-}" ]; then
        cat <<'EOF'

First we'll install Homebrew.
Then we'll install these Homebrew packages for codex-spine:
  - python
  - ripgrep
  - node
  - pnpm
  - uv
  - jq

Continue?
EOF
    else
        cat <<'EOF'

We'll install these Homebrew packages for codex-spine:
  - python
  - ripgrep
  - node
  - pnpm
  - uv
  - jq

Continue?
EOF
    fi
}

prompt_yes_no() {
    prompt=$1
    default=$2
    non_interactive=$3

    if [ "$non_interactive" -eq 1 ] || [ ! -t 0 ]; then
        [ "$default" -eq 1 ]
        return $?
    fi

    bold_on=$(printf '\033[1m')
    bold_off=$(printf '\033[0m')
    if [ "$default" -eq 1 ]; then
        suffix="[$bold_on"'Y'"$bold_off/n]"
    else
        suffix="[y/$bold_on"'N'"$bold_off]"
    fi

    printf '%s %s ' "$prompt" "$suffix" >&2
    IFS= read -r reply || reply=""
    reply=$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')
    if [ -z "$reply" ]; then
        [ "$default" -eq 1 ]
        return $?
    fi
    case "$reply" in
        y|yes)
            return 0
            ;;
    esac
    return 1
}

preflight_existing_config() {
    non_interactive=$1

    if [ ! -f "$LIVE_CONFIG_PATH" ]; then
        return 0
    fi

    if grep -q "Generated by codex-spine" "$LIVE_CONFIG_PATH" 2>/dev/null; then
        return 0
    fi

    if [ "$non_interactive" -eq 1 ] || [ ! -t 0 ]; then
        printf '%s\n' "Found an existing unmanaged Codex config at $LIVE_CONFIG_PATH. Rerun interactively so codex-spine can import the settings you want to keep into $ADOPTED_CONFIG_PATH before it makes broader install changes." >&2
        return 1
    fi

    if ! prompt_yes_no "$(cat <<EOF

Found an existing Codex config:
  $LIVE_CONFIG_PATH

codex-spine manages the memory MCP entry itself and removes any deprecated qmd_codex alias during import.
To preserve the rest of your current Codex settings, it can import them into:
  $ADOPTED_CONFIG_PATH

If you continue, codex-spine will:
  - keep the rest of your settings in that local-only overlay
  - back up the current live config
  - render a new live config that includes the imported settings

If you decline, install will stop before codex-spine changes Homebrew packages,
managed wrappers, shell files, launchd, or the live Codex config.

Continue?
EOF
)" 1 "$non_interactive"; then
        printf '%s\n' "Leaving the existing Codex config in place. codex-spine stopped before making broader install changes." >&2
        return 1
    fi

    export CODEX_SPINE_CONFIG_ADOPTION_APPROVED=1
}

jcodemunch_already_enabled() {
    if [ -f "$LOCAL_CONFIG_OVERLAY_PATH" ] && grep -q '\[mcp_servers\.jcodemunch\]' "$LOCAL_CONFIG_OVERLAY_PATH" 2>/dev/null; then
        return 0
    fi
    if [ -f "$COMPONENT_STATE_PATH" ] && grep -q 'jcodemunch-mcp' "$COMPONENT_STATE_PATH" 2>/dev/null; then
        return 0
    fi
    return 1
}

preflight_optional_jcodemunch() {
    non_interactive=$1

    if jcodemunch_already_enabled; then
        return 0
    fi

    if [ "$non_interactive" -eq 1 ] || [ ! -t 0 ]; then
        return 0
    fi

    if prompt_yes_no "$(cat <<'EOF'

Optional component: jCodeMunch MCP

If you want indexed code navigation, codex-spine can include the optional
jCodeMunch MCP integration in this install.

Later in the install, codex-spine will fetch the pinned upstream terms and ask
for explicit acknowledgement before enabling it.

Include jCodeMunch MCP in this install?
EOF
)" 1 "$non_interactive"; then
        export CODEX_SPINE_JCODEMUNCH_CHOICE=enable
    else
        export CODEX_SPINE_JCODEMUNCH_CHOICE=skip
    fi
}

ensure_bootstrap_python() {
    non_interactive=$1

    if python_bin=$("$PYTHON_LAUNCHER" --resolve 2>/dev/null); then
        BOOTSTRAP_PYTHON="$python_bin"
        return 0
    fi

    brew_path=$(find_brew || true)
    if [ -z "$brew_path" ]; then
        installer_url='https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh'
        if ! prompt_yes_no "$(brew_install_plan_prompt missing)" 1 "$non_interactive"; then
            printf '%s\n' "codex-spine needs Homebrew plus a small set of Homebrew packages. Install Homebrew from https://brew.sh, then run \`make install\` again." >&2
            return 1
        fi
        export CODEX_SPINE_BREW_INSTALL_APPROVED=1
        installer_script=$(mktemp -t codex-spine-homebrew-install.XXXXXX.sh)
        printf '\n$ curl -fL %s -o %s\n' "$installer_url" "$installer_script" >&2
        if ! curl -fL "$installer_url" -o "$installer_script" >&2; then
            rm -f "$installer_script"
            printf '%s\n' "Homebrew installer download failed. See output above for details." >&2
            return 1
        fi
        printf '\n$ /bin/bash %s\n' "$installer_script" >&2
        if ! /bin/bash "$installer_script" >&2; then
            rm -f "$installer_script"
            printf '%s\n' "Homebrew installation failed. See output above for details." >&2
            return 1
        fi
        rm -f "$installer_script"
        brew_path=$(find_brew || true)
        if [ -z "$brew_path" ]; then
            printf '%s\n' "Homebrew finished installing, but \`brew\` is still not available in this shell. Open a new shell or run the Homebrew shellenv snippet, then rerun \`make install\`." >&2
            return 1
        fi
    elif [ "${CODEX_SPINE_BREW_INSTALL_APPROVED:-0}" != "1" ]; then
        if ! prompt_yes_no "$(brew_install_plan_prompt)" 1 "$non_interactive"; then
            printf '%s\n' "codex-spine needs a small set of Homebrew packages to continue. Install them, then rerun \`make install\`." >&2
            return 1
        fi
        export CODEX_SPINE_BREW_INSTALL_APPROVED=1
    fi

    printf '\n$ %s install python\n' "$brew_path" >&2
    if ! "$brew_path" install python >&2; then
        printf '%s\n' "Homebrew Python install failed. See output above for details." >&2
        return 1
    fi

    python_bin=$("$PYTHON_LAUNCHER" --resolve 2>/dev/null || true)
    if [ -z "$python_bin" ]; then
        printf '%s\n' "Homebrew Python installed, but codex-spine still could not locate Python 3.11+. Rerun \`make install\` after confirming Homebrew Python is installed." >&2
        return 1
    fi

    BOOTSTRAP_PYTHON="$python_bin"
}

non_interactive=0
for arg in "$@"; do
    if [ "$arg" = "--non-interactive" ]; then
        non_interactive=1
    fi
done
if [ ! -t 0 ]; then
    non_interactive=1
fi

preflight_existing_config "$non_interactive"
preflight_optional_jcodemunch "$non_interactive"
ensure_bootstrap_python "$non_interactive"
exec "$BOOTSTRAP_PYTHON" "$BOOTSTRAP_PY" "$@"
