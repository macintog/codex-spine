#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PYTHON_LAUNCHER="$REPO_ROOT/bin/codex-python"
BOOTSTRAP_PY="$SCRIPT_DIR/bootstrap.py"

first_nonempty_line() {
    printf '%s\n' "$1" | sed -n '/[^[:space:]]/ { s/^[[:space:]]*//; p; q; }'
}

run_and_capture() {
    log_file=$1
    shift

    tmp_dir=$(mktemp -d -t codex-spine-bootstrap)
    fifo="$tmp_dir/output"
    mkfifo "$fifo"

    tee "$log_file" <"$fifo" &
    tee_pid=$!

    "$@" >"$fifo" 2>&1
    status=$?

    wait "$tee_pid" || true
    rm -f "$fifo"
    rmdir "$tmp_dir"
    return "$status"
}

find_brew() {
    if command -v brew >/dev/null 2>&1; then
        command -v brew
        return 0
    fi
    for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

looks_like_clt_issue() {
    lowered=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
    case "$lowered" in
        *"xcode-select: note: no developer tools were found"*|*"command line tools"*|*"xcrun: error"*|*"active developer path"*)
            return 0
            ;;
    esac
    return 1
}

prompt_yes_no() {
    prompt=$1
    default=$2
    non_interactive=$3

    if [ "$non_interactive" -eq 1 ] || [ ! -t 0 ]; then
        [ "$default" -eq 1 ]
        return $?
    fi

    if [ "$default" -eq 1 ]; then
        suffix="[Y/n]"
    else
        suffix="[y/N]"
    fi

    printf '%s %s ' "$prompt" "$suffix" >&2
    IFS= read -r reply || reply=""
    reply=$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')
    if [ -z "$reply" ]; then
        [ "$default" -eq 1 ]
        return $?
    fi
    case "$reply" in
        y|yes)
            return 0
            ;;
    esac
    return 1
}

ensure_bootstrap_python() {
    non_interactive=$1

    if python_bin=$("$PYTHON_LAUNCHER" --resolve 2>/dev/null); then
        printf '%s\n' "$python_bin"
        return 0
    fi

    brew_path=$(find_brew || true)
    if [ -z "$brew_path" ]; then
        install_command='/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
        if ! prompt_yes_no "Homebrew is required to provision the Python runtime for codex-spine bootstrap. Install Homebrew now?" 0 "$non_interactive"; then
            printf '%s\n' "Homebrew is required. Install it from https://brew.sh and rerun \`make bootstrap\`." >&2
            return 1
        fi
        printf '$ %s\n' "$install_command"
        log_file=$(mktemp -t codex-spine-homebrew-install)
        if ! run_and_capture "$log_file" /bin/bash -c "$install_command"; then
            output=$(cat "$log_file")
            rm -f "$log_file"
            detail=$(first_nonempty_line "$output")
            printf '%s\n' "Homebrew installation failed: ${detail:-unknown error}" >&2
            return 1
        fi
        rm -f "$log_file"
        brew_path=$(find_brew || true)
        if [ -z "$brew_path" ]; then
            printf '%s\n' "Homebrew install completed, but \`brew\` is still not available. Open a new shell or run the Homebrew shellenv snippet, then rerun \`make bootstrap\`." >&2
            return 1
        fi
    fi

    if ! prompt_yes_no "Install Homebrew Python now so codex-spine bootstrap can run?" 1 "$non_interactive"; then
        printf '%s\n' "Homebrew Python is required to run codex-spine bootstrap. Install it with \`brew install python\` and rerun \`make bootstrap\`." >&2
        return 1
    fi

    printf '$ %s install python\n' "$brew_path"
    log_file=$(mktemp -t codex-spine-python-install)
    if ! run_and_capture "$log_file" "$brew_path" install python; then
        output=$(cat "$log_file")
        rm -f "$log_file"
        detail=$(first_nonempty_line "$output")
        if looks_like_clt_issue "$output"; then
            printf '%s\n' "Homebrew could not install Python because Apple Command Line Tools are missing or incomplete. Finish the Command Line Tools install, open a new shell, and rerun \`make bootstrap\`." >&2
            return 1
        fi
        printf '%s\n' "Homebrew Python install failed: ${detail:-unknown error}" >&2
        return 1
    fi
    rm -f "$log_file"

    python_bin=$("$PYTHON_LAUNCHER" --resolve 2>/dev/null || true)
    if [ -z "$python_bin" ]; then
        printf '%s\n' "Homebrew Python installed, but codex-spine still could not locate Python 3.11+. Rerun \`make bootstrap\` after confirming Homebrew Python is installed." >&2
        return 1
    fi

    printf '%s\n' "$python_bin"
}

non_interactive=0
for arg in "$@"; do
    if [ "$arg" = "--non-interactive" ]; then
        non_interactive=1
    fi
done
if [ ! -t 0 ]; then
    non_interactive=1
fi

python_bin=$(ensure_bootstrap_python "$non_interactive")
exec "$python_bin" "$BOOTSTRAP_PY" "$@"
