# Non-secret machine-local overrides only.
#
# `./scripts/component-enable jcodemunch-mcp` manages the optional jGravelle Munch MCP suite block here for you.
#
# Example:
#
# Avoid top-level sandbox_mode / approval_policy here for Codex desktop use.
# Explicit values force the desktop app into "custom (config.toml)" mode.
#
# [features]
# memories = true
#
# [memories]
# use_memories = true
# generate_memories = true
# disable_on_external_context = true
#
# [projects."/absolute/path/to/a/project"]
# trust_level = "trusted"
